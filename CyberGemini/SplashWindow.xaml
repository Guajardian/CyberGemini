<Window x:Class="CyberGemini.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="Assets/CyberGemini.ico"
        Title="Cyber Gemini" Height="380" Width="580"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True">
    <Border CornerRadius="12" BorderBrush="#2A3A50" BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0A0E17" Offset="0"/>
                <GradientStop Color="#111827" Offset="0.5"/>
                <GradientStop Color="#0D1520" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Circuit / network node icon -->
                <Viewbox Height="80" Margin="0,0,0,16">
                    <Canvas Width="100" Height="100">
                        <!-- Outer ring -->
                        <Ellipse Width="90" Height="90" Canvas.Left="5" Canvas.Top="5"
                                 Stroke="#00E5FF" StrokeThickness="2" Opacity="0.6" />
                        <!-- Inner ring -->
                        <Ellipse Width="50" Height="50" Canvas.Left="25" Canvas.Top="25"
                                 Stroke="#7B61FF" StrokeThickness="2" Opacity="0.8" />
                        <!-- Center dot -->
                        <Ellipse Width="12" Height="12" Canvas.Left="44" Canvas.Top="44"
                                 Fill="#00E5FF" />
                        <!-- Cross lines -->
                        <Line X1="50" Y1="5" X2="50" Y2="25" Stroke="#00E5FF" StrokeThickness="1.5" Opacity="0.5" />
                        <Line X1="50" Y1="75" X2="50" Y2="95" Stroke="#00E5FF" StrokeThickness="1.5" Opacity="0.5" />
                        <Line X1="5" Y1="50" X2="25" Y2="50" Stroke="#7B61FF" StrokeThickness="1.5" Opacity="0.5" />
                        <Line X1="75" Y1="50" X2="95" Y2="50" Stroke="#7B61FF" StrokeThickness="1.5" Opacity="0.5" />
                        <!-- Diagonal lines -->
                        <Line X1="18" Y1="18" X2="32" Y2="32" Stroke="#00E5FF" StrokeThickness="1" Opacity="0.3" />
                        <Line X1="82" Y1="18" X2="68" Y2="32" Stroke="#00E5FF" StrokeThickness="1" Opacity="0.3" />
                        <Line X1="18" Y1="82" X2="32" Y2="68" Stroke="#7B61FF" StrokeThickness="1" Opacity="0.3" />
                        <Line X1="82" Y1="82" X2="68" Y2="68" Stroke="#7B61FF" StrokeThickness="1" Opacity="0.3" />
                    </Canvas>
                </Viewbox>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="CYBER" FontSize="32" FontWeight="Bold" Foreground="#00E5FF" />
                    <TextBlock Text="GEMINI" FontSize="32" FontWeight="Light" Foreground="#E0F7FA" Margin="8,0,0,0" />
                </StackPanel>
                <TextBlock Text="Duplicate file detection system" Foreground="#607D8B" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,6,0,0" />
            </StackPanel>

            <!-- Bottom bar -->
            <Grid Grid.Row="1">
                <ProgressBar IsIndeterminate="True" Height="2" Foreground="#00E5FF" Background="#1A2235"
                             BorderThickness="0" />
                <TextBlock Text="Initializing..." Foreground="#607D8B" HorizontalAlignment="Right"
                           FontSize="10" Margin="0,8,0,0" />
            </Grid>
        </Grid>
    </Border>
</Window>